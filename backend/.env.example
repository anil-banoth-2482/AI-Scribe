GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# History storage (AWS S3)
# - Set ENABLE_HISTORY_STORAGE=true to store meeting summaries/transcripts in S3.
# - You must set AWS_BUCKET_NAME + AWS_REGION.
# - Authentication options:
#   (A) Access keys (recommended for local/dev): set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY
#   (B) AWS CLI / IAM role (recommended for prod): leave keys empty and set AWS_PROFILE (or use an IAM role)
# - If you use temporary STS credentials, also set AWS_SESSION_TOKEN.
ENABLE_HISTORY_STORAGE=true
AWS_BUCKET_NAME=aiscribe123
AWS_REGION=ap-south-1

# (Optional) If you enable SSE-KMS, set this and update code/policy accordingly.
# AWS_KMS_KEY_ID=

RECALL_API_KEY=your_recall_api_key_here
RECALL_BASE=https://api.recall.ai/api/v1
RECALL_TRANSCRIPTION_PROVIDER=
HF_API_KEY=your_huggingface_api_key
HF_PROVIDER=fireworks-ai
